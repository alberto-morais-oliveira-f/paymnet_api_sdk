{
    "name": "am2tec/payment-api-sdk",
    "version": "1.1.0",
    "description": "Laravel SDK for the am2tec payment_api centralized payment gateway.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alberto Morais",
            "email": "albertomorais80@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Am2tec\\PaymentApiSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Am2tec\\PaymentApiSdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Am2tec\\PaymentApiSdk\\Providers\\PaymentApiServiceProvider"
            ],
            "aliases": {
                "PaymentApi": "Am2tec\\PaymentApiSdk\\Facades\\PaymentApi"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "@php vendor/bin/phpunit"
    }
}
